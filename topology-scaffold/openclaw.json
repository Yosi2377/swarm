    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_AUTH_TOKEN}"
    }
  },
  "models": {
    "providers": {
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "tools": {
    "allow": [],
    "deny": [],
    "agentToAgent": {
      "enabled": true
